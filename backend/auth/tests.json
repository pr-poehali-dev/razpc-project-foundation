{
  "tests": [
    {
      "name": "Login with nonexistent user returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "nobody_here_2731@example.com", "password": "whatever"},
      "expectedStatus": 401
    },
    {
      "name": "Register without email returns 400",
      "method": "POST",
      "path": "/?action=register",
      "body": {"password": "secret123", "name": "No Email"},
      "expectedStatus": 400
    },
    {
      "name": "Me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "Unknown action returns 400",
      "method": "GET",
      "path": "/?action=bogus",
      "expectedStatus": 400
    },
    {
      "name": "List users without token returns 401",
      "method": "GET",
      "path": "/?action=users",
      "expectedStatus": 401
    },
    {
      "name": "Set role without token returns 401",
      "method": "POST",
      "path": "/?action=set_role",
      "body": {"user_id": 1, "role": "manager"},
      "expectedStatus": 401
    },
    {
      "name": "Forgot with unknown email returns ok (no disclosure)",
      "method": "POST",
      "path": "/?action=forgot",
      "body": {"email": "nobody_here_2731@example.com"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Forgot without email returns 400",
      "method": "POST",
      "path": "/?action=forgot",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Reset with short password returns 400",
      "method": "POST",
      "path": "/?action=reset",
      "body": {"email": "a@b.com", "code": "123456", "password": "123"},
      "expectedStatus": 400
    },
    {
      "name": "Reset with wrong code returns 400",
      "method": "POST",
      "path": "/?action=reset",
      "body": {"email": "nobody_here_2731@example.com", "code": "000000", "password": "secret123"},
      "expectedStatus": 400
    }
  ]
}