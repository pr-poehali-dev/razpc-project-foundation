{
  "tests": [
    {
      "name": "List all builds",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get build detail by slug",
      "method": "GET",
      "path": "/?slug=razpc-titan",
      "expectedStatus": 200,
      "expectedBody": {"slug": "razpc-titan"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Update without admin token forbidden",
      "method": "PUT",
      "path": "/",
      "body": {"id": 1, "name": "hacked"},
      "expectedStatus": 403
    },
    {
      "name": "Delete without admin token forbidden",
      "method": "DELETE",
      "path": "/?id=1",
      "expectedStatus": 403
    },
    {
      "name": "Create without admin token forbidden",
      "method": "POST",
      "path": "/",
      "body": {"action": "create", "name": "Test build"},
      "expectedStatus": 403
    }
  ]
}