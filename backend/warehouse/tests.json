{
  "tests": [
    {
      "name": "Dashboard without token returns 401",
      "method": "GET",
      "path": "/?resource=dashboard",
      "expectedStatus": 401
    },
    {
      "name": "Models list without token returns 401",
      "method": "GET",
      "path": "/?resource=models",
      "expectedStatus": 401
    },
    {
      "name": "Units list without token returns 401",
      "method": "GET",
      "path": "/?resource=units",
      "expectedStatus": 401
    },
    {
      "name": "Lots without token returns 401",
      "method": "GET",
      "path": "/?resource=lots",
      "expectedStatus": 401
    },
    {
      "name": "Receive without token returns 401",
      "method": "POST",
      "path": "/?resource=lots&action=receive",
      "body": {"items": []},
      "expectedStatus": 401
    },
    {
      "name": "Machines without token returns 401",
      "method": "GET",
      "path": "/?resource=machines",
      "expectedStatus": 401
    },
    {
      "name": "Accounts without token returns 401",
      "method": "GET",
      "path": "/?resource=accounts",
      "expectedStatus": 401
    },
    {
      "name": "Sell without token returns 401",
      "method": "POST",
      "path": "/?resource=sell",
      "body": {"kind": "service", "price": 100},
      "expectedStatus": 401
    },
    {
      "name": "Bad token returns 401",
      "method": "GET",
      "path": "/?resource=dashboard",
      "headers": {"X-Auth-Token": "invalid-xyz"},
      "expectedStatus": 401
    },
    {
      "name": "OPTIONS returns 200",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    }
  ]
}
